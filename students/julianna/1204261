<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>1204261 — Линейная функция и модуль</title>
  <style>
    :root { --bg:#0f172a; --card:#111827; --text:#e5e7eb; --muted:#9ca3af; --acc:#22d3ee; }
    *{box-sizing:border-box} body{margin:0;font-family:system-ui;background:var(--bg);color:var(--text)}
    .wrap{max-width:900px;margin:0 auto;padding:24px}.card{background:var(--card);padding:18px;border-radius:14px}
    label,input{display:block;width:100%} input{margin-top:6px;padding:10px;border-radius:10px;border:1px solid #334155;background:#0b1220;color:var(--text)}
    .grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}.muted{color:var(--muted)}
    button{margin-top:12px;padding:10px 14px;border:0;border-radius:10px;background:var(--acc);color:#06202a;font-weight:700;cursor:pointer}
    #out{margin-top:14px;padding:10px;border-radius:10px;background:#0b1220;border:1px solid #334155}
  </style>
</head>
<body>
  <main class="wrap">
    <h1>Разбор выражения y = |ax + b|</h1>
    <p class="muted">Исправлено: добавлена проверка ввода, понятные ошибки и формула в стандартном виде.</p>
    <section class="card">
      <div class="grid">
        <label>Коэффициент a<input id="a" type="number" step="any" value="1" /></label>
        <label>Коэффициент b<input id="b" type="number" step="any" value="0" /></label>
      </div>
      <button id="calc">Показать свойства</button>
      <div id="out" aria-live="polite">Введите a и b.</div>
    </section>
  </main>
  <script>
    const aEl = document.getElementById('a');
    const bEl = document.getElementById('b');
    const out = document.getElementById('out');

    document.getElementById('calc').addEventListener('click', () => {
      const a = Number(aEl.value);
      const b = Number(bEl.value);
      if (!Number.isFinite(a) || !Number.isFinite(b)) {
        out.textContent = 'Ошибка: введите корректные числа.';
        return;
      }
      if (a === 0) {
        out.textContent = `y = |${b}| = ${Math.abs(b)} — постоянная функция.`;
        return;
      }
      const x0 = -b / a;
      const kLeft = -a;
      const kRight = a;
      out.innerHTML = `
        Нуль подмодульного выражения: <b>x₀ = ${x0.toFixed(3)}</b>.<br>
        Кусочно: y = ${kLeft.toFixed(3)}x ${b >= 0 ? '-' : '+'} ${Math.abs(b).toFixed(3)} при x &lt; ${x0.toFixed(3)},<br>
        y = ${kRight.toFixed(3)}x ${b >= 0 ? '+' : '-'} ${Math.abs(b).toFixed(3)} при x ≥ ${x0.toFixed(3)}.
      `;
    });
  </script>
</body>
</html>
