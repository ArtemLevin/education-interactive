<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>1204263 — Генератор заданий</title>
  <style>
    body{font-family:system-ui;margin:0;background:#111827;color:#e5e7eb}.wrap{max-width:760px;margin:0 auto;padding:24px}
    .card{background:#1f2937;border:1px solid #374151;border-radius:12px;padding:16px}
    button{padding:10px 12px;border-radius:10px;border:0;background:#34d399;color:#052e16;font-weight:700;cursor:pointer}
    code{background:#0b1220;padding:2px 6px;border-radius:6px}
  </style>
</head>
<body>
  <main class="wrap">
    <h1>Генератор упражнений</h1>
    <div class="card">
      <p id="task">Нажмите кнопку для генерации.</p>
      <button id="next">Новое задание</button>
      <p id="hint"></p>
    </div>
  </main>
  <script>
    const task = document.getElementById('task');
    const hint = document.getElementById('hint');

    function rnd(min, max){ return Math.floor(Math.random()*(max-min+1))+min; }

    document.getElementById('next').addEventListener('click', () => {
      let a = 0;
      while (a === 0) a = rnd(-5, 5);
      const b = rnd(-12, 12);
      task.innerHTML = `Найдите вершину графика <code>y = |${a}x ${b >= 0 ? '+' : '-'} ${Math.abs(b)}|</code>.`;
      const x0 = (-b / a).toFixed(2);
      hint.textContent = `Подсказка: приравняйте выражение под модулем к нулю: x = ${x0}.`;
    });
  </script>
</body>
</html>
