<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>1204262 — Проверка знаний</title>
  <style>
    body{margin:0;font-family:system-ui;background:#f8fafc;color:#0f172a}.wrap{max-width:760px;margin:0 auto;padding:24px}
    .q{background:#fff;border:1px solid #cbd5e1;border-radius:12px;padding:14px;margin-bottom:12px}
    button{padding:10px 12px;border:0;border-radius:10px;background:#0ea5e9;color:#fff;font-weight:700;cursor:pointer}
    .ok{color:#166534}.bad{color:#991b1b}
  </style>
</head>
<body>
  <main class="wrap">
    <h1>Мини-тест по теме |ax+b|</h1>
    <section class="q">
      <p>1) Где находится вершина графика y = |2x - 6|?</p>
      <label><input type="radio" name="q1" value="a"> x = 6</label><br>
      <label><input type="radio" name="q1" value="b"> x = 3</label><br>
      <label><input type="radio" name="q1" value="c"> x = -3</label>
    </section>
    <section class="q">
      <p>2) Сколько решений имеет |x| = -1?</p>
      <label><input type="radio" name="q2" value="a"> 1</label><br>
      <label><input type="radio" name="q2" value="b"> 2</label><br>
      <label><input type="radio" name="q2" value="c"> 0</label>
    </section>
    <button id="check">Проверить</button>
    <p id="result" aria-live="polite"></p>
  </main>
  <script>
    document.getElementById('check').addEventListener('click', () => {
      const a1 = document.querySelector('input[name="q1"]:checked')?.value;
      const a2 = document.querySelector('input[name="q2"]:checked')?.value;
      if (!a1 || !a2) {
        const r = document.getElementById('result');
        r.className = 'bad';
        r.textContent = 'Ответьте на оба вопроса.';
        return;
      }
      let score = 0;
      if (a1 === 'b') score++;
      if (a2 === 'c') score++;
      const r = document.getElementById('result');
      r.className = score === 2 ? 'ok' : 'bad';
      r.textContent = `Результат: ${score}/2`;
    });
  </script>
</body>
</html>
